{
  "version": 2,
  "rewrites": [
    { "source": "/story", "destination": "/api/story" }
  ],
  "crons": [
    {
      "path": "/api/daily-refresh?slot=am",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/daily-refresh?slot=pm",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "api/daily-refresh.js": { "maxDuration": 300 },
    "api/stories-refresh.js": { "maxDuration": 90, "includeFiles": "data/**" },
    "api/verify-recruiting.js": { "maxDuration": 90, "includeFiles": "data/**" }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
