{
  "version": 2,
  "crons": [
    {
      "path": "/api/odds?cron=1",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/generate-story?cron=1",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
