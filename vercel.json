{
  "version": 2,
  "rewrites": [
    { "source": "/story", "destination": "/api/story" }
  ],
  "crons": [
    {
      "path": "/api/orchestrator?slot=am",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/orchestrator?slot=pm",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "api/orchestrator.js": { "maxDuration": 300, "includeFiles": "{data,bots}/**" },
    "api/ops.js": { "maxDuration": 30, "includeFiles": "{data/**,bots/**,NEEDS-VERIFICATION.md}" },
    "api/stories-refresh.js": { "maxDuration": 90, "includeFiles": "{data,bots}/**" },
    "api/verify-recruiting.js": { "maxDuration": 90, "includeFiles": "{data,bots}/**" },
    "api/briefing.js": { "maxDuration": 90, "includeFiles": "{data,bots}/**" },
    "api/generate-story.js": { "maxDuration": 90, "includeFiles": "{data,bots}/**" }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
